{
  "ConnectionStrings": {
    "DefaultConnection": ""
  },
  "JwtSettings": {
    "AccessTokenExpMinutes": 60,
    "RefreshTokenExpDays": 7
  },
  "SeedAdmin": {
    "Email": "admin@atlasbalance.local"
  },
  "Security": {
    "RequireMfaForWebUsers": true
  },
  "Ia": {
    "UseSystemProxy": false,
    "ProxyUrl": ""
  },
  "WatchdogSettings": {
    "BaseUrl": "http://localhost:5001",
    "PostgresBinPath": "C:\\Program Files\\PostgreSQL\\16\\bin",
    "StateFilePath": "C:\\AtlasBalance\\watchdog-state.json",
    "DockerPostgresContainer": "atlas_balance_db",
    "UpdateSourceRoot": "C:\\AtlasBalance\\updates",
    "UpdateTargetPath": "C:\\AtlasBalance\\api"
  },
  "GitHubSettings": {
    "UpdateToken": ""
  },
  "UpdateSecurity": {
    "ReleaseSigningPublicKeyPem": ""
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.EntityFrameworkCore": "Warning",
        "Hangfire": "Warning"
      }
    }
  },
  "AllowedHosts": "localhost"
